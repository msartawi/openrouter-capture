{
  "name": "openrouter-capture",
  "version": "0.1.6",
  "private": true,
  "description": "Local Playwright helper to discover ZTE router APIs for OpenRouterDesk. Not part of the public app.",
  "license": "MIT",
  "author": "OpenRouterDesk contributors",
  "type": "module",
  "bin": {
    "openrouter-capture": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:smoke": "npm run build && node scripts/smoke-redact.mjs",
    "check": "npm run typecheck && npm run build && node scripts/smoke-redact.mjs",
    "capture": "tsx src/cli.ts",
    "crawl": "tsx src/cli.ts crawl",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "playwright": "^1.54.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
